HungarianSolver_couplr <- function(costMatrix, method = "jv", maximize = FALSE) {
  stopifnot(is.matrix(costMatrix), is.numeric(costMatrix))
  
  res <- couplr::assignment(
    cost = costMatrix,
    maximize = maximize,
    method = method
  )
  
  assigned_rows <- which(res$match > 0L)
  pairs <- cbind(
    assigned_rows,
    unname(res$match[assigned_rows])
  )
  
  list(
    cost = res$total_cost,
    pairs = pairs,
    status = res$status,
    method_used = res$method_used
  )
}

## Faster version of wasserstein_test (outer R + inner B)
## Key changes vs your original:
## 1) Avoids creating D0/G0 and Dhn0 via full n×n submatrix copies each iteration.
##    Instead, it uses index vectors and extracts only the needed (n/2)×(n/2) corner.
## 2) Builds the hybrid matrix H once per outer replicate (still needed).
## 3) Uses sample.int() and preallocated vectors.

wasserstein_test_fast <- function(mats, R, B){
  n <- dim(mats)[3]
  stopifnot(n %% 2L == 0L)
  h <- n %/% 2L
  
  # Distance matrices (compute once)
  D <- distance_logeuclid_cpp(mats)
  G <- distance_to_inverse_logeuclid_cpp(mats)
  
  pval_vec <- numeric(R)
  
  for (i in seq_len(R)) {
    
    ## Outer "bootstrap" permutation (random split)
    b <- sample.int(n)
    A0 <- b[1:h]              # first half indices under outer shuffle
    B0 <- b[(h + 1L):n]       # second half indices under outer shuffle
    
    ## Observed cost: Hungarian on G_corner without forming G0
    cost0 <- HungarianSolver_couplr(G[A0, B0])$cost
    
    ## Build hybrid matrix H for this outer replicate
    ## (equivalent to building from D0,G0 and then block-binding)
    H <- rbind(
      cbind(D[A0, A0], G[A0, B0]),
      cbind(t(G[A0, B0]), D[B0, B0])
    )
    
    perm_costs <- numeric(B)
    
    ## Inner permutation loop (null)
    for (j in seq_len(B)) {
      p <- sample.int(n)
      A <- p[1:h]
      Bidx <- p[(h + 1L):n]
      
      # Extract cross-block directly; avoid H[p,p] and then cornering
      perm_costs[j] <- HungarianSolver_couplr(H[A, Bidx])$cost
    }
    
    # Same direction as your original code (<); change to <= if desired
    pval_vec[i] <- mean(cost0 < perm_costs)
  }
  
  mean(pval_vec)
}

wasserstein_test <- function(mats, R, B){
  pval_vec <- rep(0, R)
  
  n <- dim(mats)[3]
  
  # Distance matrices
  D <- distance_logeuclid_cpp(mats)
  G <- distance_to_inverse_logeuclid_cpp(mats)
  
  
  # Bootstrap replicates
  for(i in 1:R){
    b_indices <- sample(1:n)
    
    D0 <- D[b_indices, b_indices]
    G0 <- G[b_indices, b_indices]
    
    G_corner <- G0[1:(n/2), (n/2 + 1):n]
    
    cost0 <- HungarianSolver(G_corner)$cost
    
    Dhn <- rbind(cbind(D0[1:(n/2), 1:(n/2)], G0[1:(n/2), (n/2 + 1):n]),
                 cbind(t(G0[1:(n/2), (n/2 + 1):n]), D0[(n/2 + 1):n, (n/2 + 1):n]))
    
    perm_costs <- rep(0, B)
    
    # Permutation replicates
    for(j in 1:B){
      p_indices <- sample(1:n)
      Dhn0 <- Dhn[p_indices, p_indices]
      Dhn0_corner <- Dhn0[1:(n/2), (n/2 + 1):n]
      
      perm_costs[j] <- HungarianSolver(Dhn0_corner)$cost
    }
    
    pval_vec[i] <- mean(cost0 < perm_costs)
  }
  
  mean(pval_vec)
}


