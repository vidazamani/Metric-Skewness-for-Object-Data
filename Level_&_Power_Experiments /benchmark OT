compare_hungarian_vs_lapjv <- function(mats, R, B, seed = 1L){
  set.seed(seed)
  
  n <- dim(mats)[3]
  stopifnot(n %% 2L == 0L)
  h <- n %/% 2L
  
  # Distance matrices once
  D <- distance_logeuclid_cpp(mats)
  G <- distance_to_inverse_logeuclid_cpp(mats)
  
  res <- vector("list", R)
  
  for (i in seq_len(R)) {
    b <- sample.int(n)
    D0 <- D[b, b]
    G0 <- G[b, b]
    
    # Observed corner
    Cobs <- G0[1:h, (h+1L):n]
    cost_h_obs <- RcppHungarian::HungarianSolver(Cobs)$cost
    cost_l_obs <- TreeDist::LAPJV(Cobs)[[1]]
    
    # Hybrid matrix
    H <- rbind(
      cbind(D0[1:h, 1:h],              G0[1:h, (h+1L):n]),
      cbind(t(G0[1:h, (h+1L):n]),      D0[(h+1L):n, (h+1L):n])
    )
    
    # Permuted corners
    cost_h_perm <- numeric(B)
    cost_l_perm <- numeric(B)
    
    for (j in seq_len(B)) {
      p <- sample.int(n)
      H0 <- H[p, p]
      Cperm <- H0[1:h, (h+1L):n]
      
      cost_h_perm[j] <- RcppHungarian::HungarianSolver(Cperm)$cost
      cost_l_perm[j] <- TreeDist::LAPJV(Cperm)[[1]]
    }
    
    res[[i]] <- data.frame(
      outer_rep = i,
      kind      = c("observed", rep("permuted", B)),
      inner_rep = c(NA_integer_, seq_len(B)),
      hungarian = c(cost_h_obs, cost_h_perm),
      lapjv     = c(cost_l_obs, cost_l_perm)
    )
  }
  
  df <- do.call(rbind, res)
  df$diff <- df$lapjv - df$hungarian
  df
}


